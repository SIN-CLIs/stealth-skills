#!/bin/bash
set -euo pipefail; PID="${1:?PID}"; TEXT="${2:-Ich kaufe gerne online ein.}"
FIELD=$(skylight-cli list-elements --pid "$PID" 2>/dev/null | python3 -c "
import json,sys
for e in json.load(sys.stdin)['elements']:
    if e['role'] in ('AXTextField','AXTextArea') and 'AXWebArea' in e.get('path',''):
        print(e['index']); break
")
[ -n "$FIELD" ] && skylight-cli type --pid "$PID" --element-index "$FIELD" --text "$TEXT" 2>/dev/null >/dev/null
echo "{\"status\":\"typed\",\"text\":\"$TEXT\"}"
